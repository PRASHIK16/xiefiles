# XIE Files — Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Admin panel password (change this!)
ADMIN_PASSWORD=xieadmin123

# Session secret (use a long random string in production)
SESSION_SECRET=your-very-secret-key-change-this

# File settings
MAX_FILE_SIZE_MB=100
EXPIRY_DAYS=30

# How many days after soft-delete before permanent deletion
PERMANENT_DELETE_AFTER_DAYS=7
